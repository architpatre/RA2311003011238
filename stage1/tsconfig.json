{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "..",
    "declaration": false,
    "resolveJsonModule": true
  },
  "include": ["*.ts", "../logging-middleware/logClient.ts"],
  "exclude": ["node_modules", "dist"]
}
